// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  email          String?   
  password       String
  expirationDate DateTime?
  isLocked       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  profile        Profile?  @relation(fields: [profileId], references: [id])
  profileId      String?
  
  roles          UserRole[]
}

model Profile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
  menus       ProfileMenu[]
}

model Role {
  id    String     @id @default(cuid())
  name  String     @unique
  users UserRole[]
  menus RoleMenu[]
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String   @unique
  path        String   @unique
  icon        String?
  category    String   @default("main") // "main" or "config"
  profiles    ProfileMenu[]
  roles       RoleMenu[]
}

model ProfileMenu {
  profile   Profile  @relation(fields: [profileId], references: [id])
  profileId String
  menuItem  MenuItem @relation(fields: [menuId], references: [id])
  menuId    String

  @@id([profileId, menuId])
}

model RoleMenu {
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String
  menuItem  MenuItem @relation(fields: [menuId], references: [id])
  menuId    String

  @@id([roleId, menuId])
}

model UserRole {
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@id([userId, roleId])
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @unique
  description String
  createdAt   DateTime @default(now())
}

model Log {
  id          String   @id @default(cuid())
  action      String   // e.g., "LOGIN", "USER_EDIT", "USER_LOCKED"
  userId      String?
  username    String?  // Username of the performer or target
  description String
  ip          String?
  createdAt   DateTime @default(now())
}
