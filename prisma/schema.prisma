// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  firstName      String?
  lastName       String?
  email          String?   
  password       String
  expirationDate DateTime?
  isLocked       Boolean   @default(false)
  lockUntil      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  profile        Profile?  @relation(fields: [profileId], references: [id])
  profileId      String?
  canWrite       Boolean   @default(false)
  
  licitaciones   UserLicitacion[]
}

model UserLicitacion {
  user         User       @relation(fields: [userId], references: [id])
  userId       String
  licitacion   Licitacion @relation(fields: [licitacionId], references: [id])
  licitacionId String

  @@id([userId, licitacionId])
}

model Profile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  users       User[]
  roles       ProfileRole[]
}

model Role {
  id    String     @id @default(cuid())
  name  String     @unique
  profiles ProfileRole[]
  menus RoleMenu[]
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String   @unique
  path        String   @unique
  icon        String?
  category    String   @default("main") // "main" or "config"
  roles       RoleMenu[]
}

model ProfileRole {
  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String
  role      Role    @relation(fields: [roleId], references: [id])
  roleId    String

  @@id([profileId, roleId])
}

model RoleMenu {
  role      Role     @relation(fields: [roleId], references: [id])
  roleId    String
  menuItem  MenuItem @relation(fields: [menuId], references: [id])
  menuId    String

  @@id([roleId, menuId])
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @unique
  description String
  createdAt   DateTime @default(now())
}

model Licitacion {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserLicitacion[]
  sucursales  Sucursal[]
}

model Pais {
  id      String   @id @default(cuid())
  codigo  String   @unique
  nombre  String
  regiones Region[]
}

model Region {
  id      String   @id @default(cuid())
  nombre  String
  paisId  String
  pais    Pais     @relation(fields: [paisId], references: [id], onDelete: Cascade)
  ciudades Ciudad[]
}

model Ciudad {
  id       String   @id @default(cuid())
  nombre   String
  regionId String
  region   Region   @relation(fields: [regionId], references: [id], onDelete: Cascade)
  comunas  Comuna[]
}

model Comuna {
  id         String     @id @default(cuid())
  nombre     String
  ciudadId   String
  ciudad     Ciudad     @relation(fields: [ciudadId], references: [id], onDelete: Cascade)
  sucursales Sucursal[]
}

model Sucursal {
  id           String     @id @default(cuid())
  codigo       String     @unique
  nombre       String
  direccion    String
  comunaId     String
  comuna       Comuna     @relation(fields: [comunaId], references: [id])
  licitacionId String
  licitacion   Licitacion @relation(fields: [licitacionId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Log {
  id          String   @id @default(cuid())
  action      String   // e.g., "LOGIN", "USER_EDIT", "USER_LOCKED"
  userId      String?
  username    String?  // Username of the performer or target
  description String
  ip          String?
  createdAt   DateTime @default(now())
}
